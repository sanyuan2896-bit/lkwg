:root {
  --bg: #f4efe2;
  --panel: rgba(255, 250, 238, 0.86);
  --ink: #1f2a35;
  --muted: #6c6a61;
  --gold: #c88e2f;
  --deep: #1f3a5f;
  --accent: #a53f2b;
  --line: rgba(31, 42, 53, 0.1);
  --shadow: 0 18rpx 60rpx rgba(31, 42, 53, 0.12);
}

page {
  min-height: 100%;
  background:
    radial-gradient(circle at top right, rgba(200, 142, 47, 0.2), transparent 28%),
    radial-gradient(circle at left 20%, rgba(165, 63, 43, 0.14), transparent 24%),
    linear-gradient(180deg, #efe6d2 0%, #f7f2e8 52%, #f4efe2 100%);
  color: var(--ink);
  font-family: "Times New Roman", serif;
}

.page-shell {
  padding: 28rpx 24rpx 40rpx;
}

.panel {
  background: var(--panel);
  border: 1rpx solid var(--line);
  border-radius: 28rpx;
  box-shadow: var(--shadow);
  backdrop-filter: blur(10rpx);
}

.section-title {
  font-size: 26rpx;
  letter-spacing: 4rpx;
  text-transform: uppercase;
  color: var(--muted);
}

.button-reset {
  padding: 0;
  margin: 0;
  line-height: 1;
  background: transparent;
  border: 0;
}

.button-reset::after {
  border: 0;
}
